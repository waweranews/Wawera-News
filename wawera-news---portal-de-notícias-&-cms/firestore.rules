rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: projects
    // Document ID: auto-generated or custom
    // Fields:
    //   - name: string (required)
    //   - logo: string (required, URL)
    //   - work: string (required)
    //   - driveLink: string (required, URL)
    //   - videoUrl: string (optional, URL)
    //   - order: number (required)
    //
    // Collection: settings
    // Document ID: content
    // Fields:
    //   - heroTitle: string
    //   - heroSub: string
    //   - heroText: string
    //   - aboutText: string
    //   - mission: string
    //   - vision: string
    //   - address: string
    //   - email: string
    //   - phone: string
    //   - whatsapp: string
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "comercial0waweranews@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function isValidProject(data) {
      return data.keys().hasAll(['name', 'logo', 'category', 'work', 'driveLink', 'order']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.category is string && data.category.size() > 0 &&
             isValidUrl(data.logo) &&
             data.work is string && data.work.size() > 0 && data.work.size() < 100 &&
             isValidUrl(data.driveLink) &&
             data.order is number &&
             (!('videoUrl' in data) || isValidUrl(data.videoUrl));
    }

    function isValidNews(data) {
      return data.keys().hasAll(['title', 'date', 'category', 'image', 'excerpt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.date is string &&
             data.category is string &&
             isValidUrl(data.image) &&
             data.excerpt is string && data.excerpt.size() > 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Projects: Publicly readable, admin writable
    match /projects/{projectId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidProject(request.resource.data);
    }

    // News: Publicly readable, admin writable
    match /news/{newsId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidNews(request.resource.data);
    }

    // Settings: Publicly readable, admin writable
    match /settings/content {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
